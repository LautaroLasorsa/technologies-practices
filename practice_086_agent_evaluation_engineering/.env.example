# LLM Provider Configuration
# Copy this file to .env and fill in your values.
# Without a .env file the practice defaults to local Ollama (qwen2.5:7b).

# Provider: ollama | lmstudio | openai | anthropic | google | mistral | groq
LLM_PROVIDER=ollama

# Chat model (without provider prefix)
LLM_MODEL=qwen2.5:7b

# Base URL override (leave empty to use the provider's default)
# ollama   default: http://localhost:11434
# lmstudio default: http://localhost:1234/v1
LLM_BASE_URL=

# API key (required for cloud providers; leave empty for local providers)
LLM_API_KEY=

# Optional: override the *judge* model independently of the agent model.
# If unset, the same model as above is used for both agent and judge.
JUDGE_PROVIDER=
JUDGE_MODEL=

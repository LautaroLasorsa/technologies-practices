# LLM provider configuration — copy to .env and edit as needed.
# All variables are optional; the defaults use Ollama with qwen2.5:7b.

# Provider: ollama (default) | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name without provider prefix (provider prefix is added automatically).
# Ollama examples:  qwen2.5:7b  llama3.1:8b  mistral:7b
# OpenAI examples:  gpt-4o  gpt-4o-mini
# Anthropic examples: claude-3-haiku-20240307  claude-3-5-sonnet-20241022
# Google examples: gemini-1.5-flash  gemini-1.5-pro
LLM_MODEL=qwen2.5:7b

# Base URL override (optional — each provider has a sensible default).
# Ollama default:   http://localhost:11434
# LM Studio default: http://localhost:1234/v1
# LLM_BASE_URL=

# API key for cloud providers (not needed for Ollama/LM Studio).
# LLM_API_KEY=your-key-here

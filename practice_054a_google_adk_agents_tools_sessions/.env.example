# LLM Provider Configuration
# Copy this file to .env and fill in the values for your provider.
# The default (no env vars) uses Ollama with qwen2.5:7b.

# Provider: ollama (default) | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name without provider prefix
LLM_MODEL=qwen2.5:7b

# Base URL override — leave empty to use the provider default:
#   ollama   → http://localhost:11434
#   lmstudio → http://localhost:1234/v1
LLM_BASE_URL=

# API key for cloud providers (openai, anthropic, google).
# Not required for local providers (ollama, lmstudio).
LLM_API_KEY=

# -----------------------------------------------------------------------
# Provider examples (uncomment and adjust as needed):
# -----------------------------------------------------------------------

# --- Ollama (default, no changes needed) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b

# --- LM Studio ---
# LLM_PROVIDER=lmstudio
# LLM_MODEL=lmstudio-community/qwen2.5-7b

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-haiku-20240307
# LLM_API_KEY=sk-ant-...

# --- Google Gemini ---
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=AIza...

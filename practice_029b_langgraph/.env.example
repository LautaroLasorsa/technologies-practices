# LLM Provider Configuration for Practice 029b
# Copy this file to .env and fill in the values for your chosen provider.
# Default (no .env file) uses local Ollama on http://localhost:11434.

# Provider: ollama | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name (must be available on your chosen provider)
LLM_MODEL=qwen2.5:3b

# Base URL override (optional — defaults are set per provider)
# ollama default:   http://localhost:11434
# lmstudio default: http://localhost:1234/v1
# LLM_BASE_URL=

# API key for cloud providers (openai, anthropic, google)
# LLM_API_KEY=

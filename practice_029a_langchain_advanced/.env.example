# LLM Provider Configuration for Practice 029a
# Copy this file to .env and fill in values for your chosen provider.
# The default (no env vars) uses local Ollama at http://localhost:11434.

# Provider: ollama (default) | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name — must match what the provider expects
LLM_MODEL=qwen2.5:3b

# Base URL override (optional — defaults per provider apply if left empty)
# Ollama default:    http://localhost:11434
# LM Studio default: http://localhost:1234/v1
LLM_BASE_URL=

# API key for cloud providers (not needed for ollama/lmstudio)
LLM_API_KEY=

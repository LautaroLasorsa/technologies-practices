# LLM Provider Configuration
# Copy this file to .env and fill in your values.
# The defaults work with a local Ollama instance — no changes needed for local dev.

# Provider: ollama (default), lmstudio, openai, anthropic, google
LLM_PROVIDER=ollama

# Model name without provider prefix
LLM_MODEL=qwen2.5:7b

# Optional: override the provider base URL
# LLM_BASE_URL=http://localhost:11434

# Optional: API key for cloud providers (openai, anthropic, google)
# LLM_API_KEY=your-api-key-here

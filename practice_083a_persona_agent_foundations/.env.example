# LLM Provider Configuration
# Copy this file to .env and fill in the values for your chosen provider.
# The agent reads these at startup. data/config.json values take precedence
# over defaults, but env vars take precedence over both.

# --- Provider selection ---
# Options: ollama (default) | lmstudio | openai | anthropic
LLM_PROVIDER=ollama

# --- Model name ---
# Ollama example:    qwen3:8b, qwen2.5:3b, llama3.2:3b
# LM Studio example: lmstudio-community/Qwen2.5-3B-Instruct-GGUF
# OpenAI example:    gpt-4o-mini, gpt-4o
# Anthropic example: claude-3-5-haiku-latest, claude-opus-4-5
LLM_MODEL=qwen3:8b

# --- Base URL override ---
# Leave empty to use the provider's default URL:
#   ollama:   http://localhost:11434/v1
#   lmstudio: http://localhost:1234/v1
#   openai:   (SDK default, no override needed)
#   anthropic:(SDK default, no override needed)
LLM_BASE_URL=

# --- API key ---
# Not required for local providers (ollama, lmstudio).
# Required for openai and anthropic.
LLM_API_KEY=

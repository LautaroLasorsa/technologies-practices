# LLM Provider Configuration for Practice 030c
# Copy this file to .env and fill in the values for your chosen provider.
# Without a .env file the practice defaults to Ollama (http://localhost:11434).

# Which provider to use.
# Options: ollama (default) | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model to use. Defaults per provider:
#   ollama/lmstudio -> qwen2.5:7b
#   openai          -> gpt-4o-mini
#   anthropic       -> claude-3-5-haiku-latest
#   google          -> gemini/gemini-2.0-flash-lite
LLM_MODEL=qwen2.5:7b

# Base URL override. Leave blank to use the provider default.
#   ollama default   -> http://localhost:11434
#   lmstudio default -> http://localhost:1234
#   openai default   -> https://api.openai.com/v1
LLM_BASE_URL=

# API key. Required for cloud providers; leave blank for ollama / lmstudio.
LLM_API_KEY=

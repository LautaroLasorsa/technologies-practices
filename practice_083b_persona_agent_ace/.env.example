# LLM Provider Configuration
# Copy this file to .env and fill in values for your chosen provider.
# Default (no .env): uses local Ollama at http://localhost:11434/v1

# Provider selection
# Options: ollama (default) | lmstudio | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name passed to the provider
# Default: qwen2.5:3b  (must be pulled into Ollama first)
LLM_MODEL=qwen2.5:3b

# Base URL override (leave blank to use the provider's default)
# ollama default:   http://localhost:11434/v1
# lmstudio default: http://localhost:1234/v1
# openai:           https://api.openai.com/v1  (set automatically)
LLM_BASE_URL=

# API key (required for cloud providers; ignored for ollama/lmstudio)
LLM_API_KEY=

# --- Examples ---

# OpenAI GPT-4o
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Anthropic Claude 3.5 Sonnet
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=sk-ant-...

# LM Studio (local, OpenAI-compatible)
# LLM_PROVIDER=lmstudio
# LLM_MODEL=lmstudio-community/qwen2.5-3b-instruct
# LLM_BASE_URL=http://localhost:1234/v1

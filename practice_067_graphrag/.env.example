# ============================================================
# LLM Configuration for practice_067_graphrag
# ============================================================
# Copy this file to .env and adjust for your provider.
# Without a .env file the scripts default to Ollama on localhost.
#
# IMPORTANT: settings.yaml (for GraphRAG's indexing/query CLI) is
# configured separately — see the "GraphRAG settings.yaml" section
# at the bottom of this file.
# ============================================================


# -----------------------------------------------------------
# PYTHON EXERCISE SCRIPTS (src/*.py)
# -----------------------------------------------------------
# These variables are read by src/llm_config.py at import time.

# Provider name — used only to set sensible URL/key defaults.
# One of: ollama | lmstudio | openai | groq | (anything else)
LLM_PROVIDER=ollama

# Model identifier passed to the API (provider-specific string).
LLM_MODEL=qwen2.5:7b

# Base URL for the chat endpoint.
# Ollama:   http://localhost:11434
# LM Studio: http://localhost:1234/v1
# OpenAI:   (leave blank — SDK fills it automatically)
# Groq:     https://api.groq.com/openai/v1
LLM_BASE_URL=

# API key.
# Ollama/LM Studio: any non-empty string (e.g. "ollama")
# OpenAI / Groq: your real key
LLM_API_KEY=

# --- Embedding model (same pattern) ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=


# ============================================================
# GRAPHRAG INDEXING / QUERY CLI  (settings.yaml)
# ============================================================
# The `graphrag index` and `graphrag query` commands read
# settings.yaml, NOT these env vars.  Configure it manually
# after running `uv run graphrag init --root .`.
#
# Below are ready-to-paste snippets for each provider.
# ============================================================

# -----------------------------------------------------------
# OLLAMA (default)
# -----------------------------------------------------------
# models:
#   default_chat_model:
#     type: openai_chat
#     model: qwen2.5:7b
#     api_base: http://localhost:11434/v1
#     api_key: ollama
#
#   default_embedding_model:
#     type: openai_embedding
#     model: nomic-embed-text
#     api_base: http://localhost:11434/v1
#     api_key: ollama

# -----------------------------------------------------------
# LM STUDIO
# -----------------------------------------------------------
# models:
#   default_chat_model:
#     type: openai_chat
#     model: <model-identifier-shown-in-lmstudio>
#     api_base: http://localhost:1234/v1
#     api_key: lmstudio
#
#   default_embedding_model:
#     type: openai_embedding
#     model: <embedding-model-identifier>
#     api_base: http://localhost:1234/v1
#     api_key: lmstudio

# -----------------------------------------------------------
# OPENAI
# -----------------------------------------------------------
# models:
#   default_chat_model:
#     type: openai_chat
#     model: gpt-4o-mini
#     api_key: ${GRAPHRAG_API_KEY}    # set in the [api_keys] section or system env
#
#   default_embedding_model:
#     type: openai_embedding
#     model: text-embedding-3-small
#     api_key: ${GRAPHRAG_API_KEY}

# -----------------------------------------------------------
# GROQ
# -----------------------------------------------------------
# models:
#   default_chat_model:
#     type: openai_chat
#     model: llama-3.3-70b-versatile
#     api_base: https://api.groq.com/openai/v1
#     api_key: <your-groq-key>
#
#   default_embedding_model:
#     # Groq does not provide embeddings — use a local or OpenAI model.

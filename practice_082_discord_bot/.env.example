# Discord Bot Token — get this from https://discord.com/developers/applications
# Go to your Application -> Bot -> "Reset Token" or "Copy" if visible
DISCORD_TOKEN=your_bot_token_here

# Test Guild (Server) ID — right-click your server name in Discord (Developer Mode must be on)
# Settings -> Advanced -> Developer Mode -> ON, then right-click server -> "Copy Server ID"
TEST_GUILD_ID=123456789012345678

# (Optional) Role message ID — filled in after running /roles_embed
# The bot logs this ID when it sends the embed; paste it here for persistence across restarts
ROLE_MESSAGE_ID=
